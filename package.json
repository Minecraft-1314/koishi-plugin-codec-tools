{
  "name": "koishi-plugin-codec-tools",
  "description": "编码&解码 URL/Base64/Unicode的 Koishi 插件",
  "version": "1.1.2",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "files": [
    "lib",
    "dist",
    "src/locales"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -b && copyfiles -u 1 src/locales/**/* lib/",
    "clean": "tsc -b --clean"
  },
  "keywords": [
    "chatbot",
    "koishi",
    "plugin",
    "codec",
    "url",
    "base64",
    "unicode",
    "qrcode",
    "barcode",
    "i18n",
    "本地化"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Minecraft-1314/koishi-plugin-codec-tools.git"
  },
  "bugs": {
    "url": "https://github.com/Minecraft-1314/koishi-plugin-codec-tools/issues"
  },
  "homepage": "https://github.com/Minecraft-1314/koishi-plugin-codec-tools#readme",
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@zxing/library": "^0.21.3",
    "jimp": "^0.16.13",
    "jsqr": "^1.4.0",
    "yaml": "^2.3.4"
  },
  "peerDependencies": {
    "koishi": "^4.18.7"
  },
  "koishi": {
    "service": {
      "required": [
        "i18n"
      ],
      "optional": []
    }
  }
}
